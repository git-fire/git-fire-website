---
export interface Props {
	product: 'git-fire' | 'git-rain';
	title?: string;
	/** Tighter block for hero cards: no heading, smaller chrome */
	embedded?: boolean;
}

const { product, title = 'Install', embedded = false } = Astro.props;

const releasesUrl =
	product === 'git-fire'
		? 'https://github.com/git-fire/git-fire/releases'
		: 'https://github.com/git-fire/git-rain/releases';

const labelId = `platform-label-${product}`;
---

<div
	class:list={['install-picker', embedded && 'install-picker--embedded']}
	data-install-picker
	data-product={product}
>
	{!embedded && <p class="install-picker__title">{title}</p>}
	<label id={labelId} for={`platform-${product}`}>{embedded ? 'Install' : 'Platform'}</label>
	<select id={`platform-${product}`} data-install-select aria-labelledby={labelId}>
		<option value="macos">macOS — Homebrew</option>
		<option value="windows">Windows — winget</option>
		<option value="linux">Linux</option>
		<option value="go">Any — Go install</option>
	</select>
	<pre><code data-install-command></code></pre>
	<div class="install-picker__actions">
		<button type="button" data-install-copy>Copy</button>
	</div>
	<p class="install-picker__note" data-install-note></p>
	<p class="install-picker__links">
		<a href={releasesUrl} target="_blank" rel="noopener noreferrer">GitHub Releases</a>
		— checksums and binary archives
	</p>
</div>
