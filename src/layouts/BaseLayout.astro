---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	featured?: 'fire' | 'rain';
}

const {
	title,
	description = 'git-fire checkpoints every repo; git-rain syncs them back down. Libraries: git-testkit and git-harness.',
	ogImage = '/favicon.svg',
	featured = 'fire',
} = Astro.props;

const fullTitle = title === 'git-fire' ? title : `${title} · git-fire`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-featured={featured}>
	<head>
		<meta charset="UTF-8" />
		<script is:inline>
			(function () {
				document.documentElement.classList.add('js');
				// Theme — read stored pref or fall back to system preference
				try {
					var t = localStorage.getItem('git-fire-theme');
					if (t !== 'light' && t !== 'dark') {
						t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
					}
					document.documentElement.setAttribute('data-theme', t);
				} catch (e) {
					document.documentElement.setAttribute('data-theme', 'dark');
				}
				// Hero variant A/B
				document.documentElement.dataset.heroVariant = 'a';
				try {
					var k = 'git-fire-site-hero-variant';
					var v = sessionStorage.getItem(k);
					if (v !== 'a' && v !== 'b') {
						v = Math.random() < 0.5 ? 'a' : 'b';
						sessionStorage.setItem(k, v);
					}
					document.documentElement.dataset.heroVariant = v;
				} catch (e) {
					/* private mode */
				}
				var h = typeof location !== 'undefined' ? location.hash : '';
				if (!h || h === '#') {
					if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, Astro.site)} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="author" content="Ben Schellenberger" />
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<header class="site-header">
			<div class="wrap site-header__inner">
				<a class="site-logo" href="/">{featured === 'rain' ? 'git-rain' : 'git-fire'}</a>
				<div class="site-header__right">
					<nav class="site-nav" aria-label="Page">
						<a href="#git-fire" data-project="fire">git-fire</a>
						<a href="#git-rain" data-project="rain">git-rain</a>
						<a href="#testkit" data-project="testkit">git-testkit</a>
						<a href="#harness" data-project="harness">git-harness</a>
					</nav>
					<button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark theme">
						<!-- Sun: shown in dark mode -->
						<svg class="theme-toggle__icon theme-toggle__icon--sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="12" r="4"/>
							<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
						</svg>
						<!-- Moon: shown in light mode -->
						<svg class="theme-toggle__icon theme-toggle__icon--moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
						</svg>
					</button>
				</div>
			</div>
		</header>
		<slot />
		<footer class="footer">
			<div class="wrap">
				<p>
					Open source (MIT). Also on
					<a href="https://git-fire.sh" rel="noopener noreferrer">git-fire.sh</a>
					and
					<a href="https://git-fire.dev" rel="noopener noreferrer">git-fire.dev</a>
					— use <strong>git-fire.com</strong> as the canonical site for links and SEO.
					Created by <a href="https://github.com/bschellenberger2600" rel="noopener noreferrer">Ben Schellenberger</a>.
				</p>
			</div>
		</footer>
		<script is:inline>
			(function () {
				var h = location.hash;
				if (!h || h === '#') {
					window.scrollTo(0, 0);
					requestAnimationFrame(function () {
						window.scrollTo(0, 0);
					});
				}
			})();
		</script>
		<script is:inline>
			(function () {
				var btn = document.getElementById('theme-toggle');
				if (!btn) return;
				btn.addEventListener('click', function () {
					var current = document.documentElement.getAttribute('data-theme');
					var next = current === 'light' ? 'dark' : 'light';
					document.documentElement.setAttribute('data-theme', next);
					try { localStorage.setItem('git-fire-theme', next); } catch (e) {}
				});
			})();
		</script>
		<script>
			import { initRevealOnScroll } from '../scripts/reveal-on-scroll.ts';
			import { initInPageNav } from '../scripts/in-page-nav.ts';
			initRevealOnScroll();
			initInPageNav();
		</script>
	</body>
</html>
